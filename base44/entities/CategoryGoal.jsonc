{
  "name": "CategoryGoal",
  "type": "object",
  "properties": {
    "category": {
      "type": "string",
      "description": "Variable expense category name (matches RiseUp category display name)"
    },
    "monthly_target": {
      "type": "number",
      "description": "Monthly spending ceiling for this category in ILS"
    }
  },
  "required": [
    "category",
    "monthly_target"
  ]
}