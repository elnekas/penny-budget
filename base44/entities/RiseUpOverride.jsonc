{
  "name": "RiseUpOverride",
  "type": "object",
  "properties": {
    "tx_id": {
      "type": "string",
      "description": "Stable id of the RiseUp transaction this override applies to"
    },
    "category": {
      "type": "string",
      "description": "Manually assigned category (overrides the RiseUp category)"
    },
    "ignored": {
      "type": "boolean",
      "default": false,
      "description": "Exclude this transaction from totals (duplicate / internal)"
    },
    "planned": {
      "type": "boolean",
      "default": false,
      "description": "Outstanding planned expense (big trip, annual payment) \u2014 tallies against savings instead of the monthly spend"
    }
  },
  "required": [
    "tx_id"
  ]
}